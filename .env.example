# Пример тестового изображения
TEST_IMAGE_URL=https://example.com/image.jpg

# GigaChat auth (Base64 от client_id:client_secret)
GIGACHAT_BASIC_AUTH=

# GigaChat endpoints
GIGACHAT_VERIFY=false
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
GIGACHAT_EMBEDDINGS_URL=https://gigachat.devices.sberbank.ru/api/v1/embeddings
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_CHAT_MODEL=GigaChat
GIGACHAT_VISION_MODEL=GigaChat-Pro
GIGACHAT_EMBEDDINGS_MODEL=Embeddings
GIGACHAT_TIMEOUT=60
IMAGE_DOWNLOAD_TIMEOUT=120

# SQLite database
DATABASE_PATH=data/analyses.db
